# Neon Postgres connection string
# Get from https://console.neon.tech (free tier)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT secret for sessions - generate with: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-una-cadena-aleatoria-larga-de-al-menos-32-caracteres"

# Admin password (you, the organizer)
ADMIN_PASSWORD="elige-una-contrasena-segura"
