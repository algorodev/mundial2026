# ── Base de datos ──────────────────────────────────────────────────────────
# Neon Postgres connection string. Free tier sobra para amigos.
# Saca el string desde https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ── Sesiones ───────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Generar: openssl rand -base64 48
JWT_SECRET="cambia-esto-por-una-cadena-aleatoria-larga-de-al-menos-32-caracteres"

# ── URL pública ────────────────────────────────────────────────────────────
# Se usa para construir los enlaces de los magic links del email y para
# canonical/openGraph en el SEO. En local: http://localhost:3000
APP_URL="https://porrabros.com"

# ── Resend (envío de magic links) ──────────────────────────────────────────
# API key desde https://resend.com/api-keys.
# El dominio de EMAIL_FROM tiene que estar verificado en Resend
# (https://resend.com/domains). Mientras pruebas puedes usar
# "PorraBros <onboarding@resend.dev>" pero solo manda a tu propio email.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="PorraBros <noreply@porrabros.com>"

# ── Admin global ───────────────────────────────────────────────────────────
# Email que `pnpm db:seed` promociona a global admin. También se usa por
# defecto en `pnpm tsx scripts/admin-link.ts` para generar magic links.
ADMIN_EMAIL="admin@porrabros.com"
